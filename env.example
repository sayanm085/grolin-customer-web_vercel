# ──────────────────────────────────────────
# Grolin Customer Web — Environment Variables
# Copy this to .env.local and fill in values
# ──────────────────────────────────────────

# Backend API
NEXT_PUBLIC_API_URL=https://grolin.shotlin.in/api/v1
NEXT_PUBLIC_API_PROXY_PATH=/api/v1

# Socket.IO
# For Vercel / production, never use localhost here.
NEXT_PUBLIC_SOCKET_URL=https://grolin.shotlin.in

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# App
NEXT_PUBLIC_APP_NAME=Grolin Grocery
NEXT_PUBLIC_ENV=development
